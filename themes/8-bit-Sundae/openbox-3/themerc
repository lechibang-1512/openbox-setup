!! 8-bit Sundae by Antigravity
!! Playful, premium retro-candy theme with strawberry, vanilla, and chocolate accents.

!! General
window.handle.width: 4
window.client.padding.width: 1
window.client.padding.height: 1
border.Width: 2
padding.width: 5
menu.overlap: 2
border.color: #5c3d2e
window.frameColor: #fffcf9
window.*.client.color: #fffcf9
*.text.justify: center

!! Fonts
window.active.label.text.font: shadow=y:shadowoffset=1:shadowtint=20
window.inactive.label.text.font: shadow=n
menu.items.font:
menu.title.text.font: shadow=y:shadowoffset=1:shadowtint=20

!! Menu Styling (Strawberry Pink & Mint Green sundae colors!)
menu.border.color: #5c3d2e
menu.title.bg: flat border vertical gradient 
menu.title.bg.color: #ff7b90
menu.title.bg.colorTo: #ff9aa2
menu.title.bg.border.color: #ffccd5
menu.title.text.color: #ffffff

menu.items.bg: flat border solid
menu.items.bg.color: #fffcf9
menu.items.bg.border.color: #fdf6ec
menu.items.text.color: #3a2010

menu.items.disabled.text.color: #d7ccc8

menu.items.active.bg: flat solid
menu.items.active.bg.color: #a8e6cf
menu.items.active.text.color: #3a2010
menu.items.active.bg.border.color: #5c3d2e

!! Active Window Styling (Strawberry Pink to Orange-Vanilla Peach)
window.active.title.bg: flat border vertical gradient
window.active.title.bg.color: #ff7b90
window.active.title.bg.colorTo: #ffd3b6
window.active.title.bg.border.color: #ffccd5

window.active.label.bg: parentrelative
window.active.label.text.color: #3a2010

window.active.button.*.bg: parentrelative
window.active.button.*.image.color: #3a2010
window.active.button.hover.bg.color: #fdf6ec
window.active.button.hover.image.color: #ff7b90
window.active.button.pressed.bg.color: #ffccd5
window.active.button.disabled.image.color: #ffccd5

window.active.handle.bg: raised solid
window.active.handle.bg.color: #ffd3b6
window.*.grip.bg: parentrelative

!! Inactive Window Styling (Vanilla Cream & Almond Gray)
window.inactive.title.bg: flat border vertical gradient
window.inactive.title.bg.color: #fffaf0
window.inactive.title.bg.colorTo: #f5ebe6
window.inactive.title.bg.border.color: #fffcf9
window.inactive.label.bg: parentrelative
window.inactive.label.text.color: #bcaaa4

window.inactive.button.*.bg: parentrelative
window.inactive.button.*.image.color: #bcaaa4
window.inactive.button.pressed.bg.color: #f5ebe6
window.inactive.button.disabled.image.color: #e0d8d5

window.inactive.handle.bg: raised solid
window.inactive.handle.bg.color: #f5ebe6
